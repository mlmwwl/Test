#!name=🗺️ Apple Maps 国际化覆写
#!desc=将 Apple 地图的中国大陆节点重定向至国际节点，包含地图瓦片、路况、导航及地理配置修正
#!author=Claude
#!version=1.1

[URL Rewrite]
# 🗺️ 地图瓦片：CN 节点 → 国际节点
^https://gspe19-cn-ssl\.ls\.apple\.com/tiles https://gspe19-ssl.ls.apple.com/tiles 302

# 🗺️ 其他地图资源：CN 节点 → 国际节点
^https://gspe19-cn-ssl\.ls\.apple\.com/ https://gspe19-ssl.ls.apple.com/ 302

# 🚦 路况数据：CN 节点 → 国际节点
^https://gspe12-cn-ssl\.ls\.apple\.com/traffic https://gspe12-ssl.ls.apple.com/traffic 302

# 🚦 其他路况资源：CN 节点 → 国际节点
^https://gspe12-cn-ssl\.ls\.apple\.com/ https://gspe12-ssl.ls.apple.com/ 302

# 🔗 gspe11 CN 节点 → 国际节点
^https://gspe11-2-cn-ssl\.ls\.apple\.com/ https://gspe11--ssl.ls.apple.com/ 302

# 🧭 导航路线：高德 → Apple 国际
^https://direction2\.is\.autonavi\.com/direction https://gsp-ssl.ls.apple.com/directions.arpc 302

# 📍 地理配置 country_code=CN → country_code=US
^(https://gspe35-ssl\.ls\.apple\.com/geo_manifest/dynamic/config\?.*?)country_code=CN(.*) $1country_code=US$2 302

[MITM]
hostname = gspe19-cn-ssl.ls.apple.com, gspe12-cn-ssl.ls.apple.com, gspe11-2-cn-ssl.ls.apple.com, direction2.is.autonavi.com, gspe35-ssl.ls.apple.com
