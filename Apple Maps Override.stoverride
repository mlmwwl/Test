#!name=🗺️ Apple Maps 国际化覆写
#!desc=将 Apple 地图的中国大陆节点重定向至国际节点，包含地图瓦片、路况、导航及地理配置修正
#!system=3
#!author=Claude
#!version=1.0
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Apple.png

[Rule]
# 拦截 Apple 地图地理配置（country_code 修正）
URL-REGEX,^https://gspe35-ssl\.ls\.apple\.com/geo_manifest/dynamic/config.*country_code=CN,DIRECT,requires-body=1,max-size=0,script-response-body=convertCountryCode.js

[URL Rewrite]
# 🗺️ 地图瓦片：CN 节点 → 国际节点
^https://gspe19-cn-ssl\.ls\.apple\.com/tiles https://gspe19-ssl.ls.apple.com/tiles 302

# 🚦 路况数据：CN 节点 → 国际节点
^https://gspe12-cn-ssl\.ls\.apple\.com/traffic https://gspe12-ssl.ls.apple.com/traffic 302

# 🧭 导航路线：高德 → Apple 国际
^https://direction2\.is\.autonavi\.com/direction https://gsp-ssl.ls.apple.com/directions.arpc 302

[Header Rewrite]
# 地图瓦片域名头部替换
^https://gspe19-cn-ssl\.ls\.apple\.com/ header-replace Host gspe19-ssl.ls.apple.com

# 路况数据头部替换
^https://gspe12-cn-ssl\.ls\.apple\.com/ header-replace Host gspe12-ssl.ls.apple.com

[MITM]
hostname = gspe19-cn-ssl.ls.apple.com, gspe12-cn-ssl.ls.apple.com, gspe11-2-cn-ssl.ls.apple.com, direction2.is.autonavi.com, gspe35-ssl.ls.apple.com

[Script]
# country_code=CN → country_code=US 修正脚本
convertCountryCode.js = type=http-response,pattern=^https://gspe35-ssl\.ls\.apple\.com/geo_manifest/dynamic/config.*country_code=CN,requires-body=1,max-size=0,script-path=convertCountryCode.js
